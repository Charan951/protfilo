@page
@model Brian_Kabbo_Sarker.IndexModel
@{
    ViewData["Title"] = "Brian Kabbo Sarker";
}

<!-- Animated Background Canvas -->
<canvas id="hero-canvas" class="hero-canvas"></canvas>

<!-- Home Section -->
<section id="home" class="hero-balance" data-aos="fade-in">

    <!-- Greeting and Name -->
    <div class="hero-text-container">
        <p class="hero-greeting" data-aos="fade-up" data-aos-delay="100">
            Hello, this is
        </p>
        <h1 class="hero-name" data-aos="fade-up" data-aos-delay="200">
            Brian Kabbo
        </h1>

        <!-- Professional Identity -->
        <p class="hero-identity" data-aos="fade-up" data-aos-delay="400">
            <span class="identity-text">Software Developer Crafting with</span>
            <span class="dotnet-highlight">.NET</span>
        </p>
    </div>

    <!-- CTA Stack -->
    <div class="hero-cta-stack" data-aos="fade-up" data-aos-delay="600">
        <a href="#showcase" class="crystal-glass-btn">
            <span class="btn-text">View Work</span>
        </a>
        <a href="~/files/Brian_Kabbo_Sarker_CV.pdf" download class="crystal-glass-btn">
            <span class="btn-text">Download CV</span>
        </a>
    </div>

</section>

<!-- About Section -->
<section id="about" class="py-16 max-w-6xl mx-auto px-6 section-reveal">

    <!-- Heading -->
    <h2
        class="text-3xl md:text-4xl font-extrabold uppercase tracking-wider text-[#FFF1F1] text-center mb-12 flex items-center justify-center">
        <span class="border-t border-[#64ffda]/50 flex-[0_0_60px] mr-3"></span>
        ABOUT
        <span class="border-t border-[#64ffda]/50 flex-[0_0_60px] ml-3"></span>
    </h2>

    <div class="flex flex-col md:flex-row items-center justify-between gap-12">

        <!-- Bio and Skills (Left) -->
        <div class="md:w-1/2 space-y-6 order-2 md:order-1">
            <p class="text-[#e6f1ff] text-lg section-reveal">
                Hi, I'm <span class="text-[#64ffda] font-semibold">Brian Kabbo Sarker</span> - a passionate software
                developer who enjoys crafting modern, playful, and professional web experiences. I graduated in Computer
                Science & Engineering from <span class="text-[#64ffda] font-semibold">Green University of
                    Bangladesh</span>.
            </p>

            <p class="text-[#e6f1ff] text-lg section-reveal">
                I specialize in creating interactive UI effects, responsive layouts, and full-stack web applications
                that leave a lasting impression.
            </p>

            <!-- Skills - How I Build Things -->
            <div class="section-reveal">
                <h3 class="text-2xl text-[#e6f1ff] font-bold mb-6 mt-8">How I build things</h3>

                <!-- Languages & Frameworks -->
                <div class="mb-6">
                    <h4 class="text-sm text-[#8892b0] font-semibold mb-3 uppercase tracking-wider">Languages &
                        Frameworks</h4>
                    <div class="flex flex-wrap gap-3">
                        <span class="skill-badge">C#</span>
                        <span class="skill-badge">TypeScript</span>
                        <span class="skill-badge">React</span>
                        <span class="skill-badge">Tailwind CSS</span>
                        <span class="skill-badge">Python</span>
                        <span class="skill-badge">MySQL</span>
                    </div>
                </div>

                <!-- AI & Machine Learning -->
                <div class="mb-6">
                    <h4 class="text-sm text-[#8892b0] font-semibold mb-3 uppercase tracking-wider">AI & Machine Learning
                    </h4>
                    <div class="flex flex-wrap gap-3">
                        <span class="skill-badge">OpenAI API</span>
                        <span class="skill-badge">Google Generative AI</span>
                        <span class="skill-badge">Claude Sonnet</span>
                        <span class="skill-badge">Gemini</span>
                    </div>
                </div>

                <!-- Tools -->
                <div>
                    <h4 class="text-sm text-[#8892b0] font-semibold mb-3 uppercase tracking-wider">Tools</h4>
                    <div class="flex flex-wrap gap-3">
                        <span class="skill-badge">Git</span>
                        <span class="skill-badge">GitHub</span>
                        <span class="skill-badge">VS Code</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Profile Photo (Right) -->
        <div class="md:w-1/2 flex justify-center order-1 md:order-2 section-reveal">
            <img src="~/images/profile-photo.jpg" alt="Brian Kabbo Sarker"
                class="w-48 h-48 md:w-80 md:h-80 rounded-xl shadow-2xl border-4 border-[#7CF5FF] object-cover transform transition-transform duration-500 hover:scale-105" />
        </div>

    </div>
</section>



<!-- Experience Section -->
<section id="experience" class="py-16 max-w-6xl mx-auto px-6 section-reveal">

    <h2 class="text-3xl md:text-4xl font-extrabold uppercase tracking-wider
               text-[#FFF1F1] text-center mb-12 flex items-center justify-center">
        <span class="border-t border-[#64ffda]/50 flex-[0_0_60px] mr-3"></span>
        EXPERIENCE
        <span class="border-t border-[#64ffda]/50 flex-[0_0_60px] ml-3"></span>
    </h2>

    <div class="flex flex-col md:flex-row gap-10">

        <!-- Sidebar -->
        <div class="flex flex-wrap md:flex-col md:w-1/4 gap-3 md:sticky md:top-36">

            <button class="experience-tab active-tab" data-company="company1">
                The Christian Co-Operative Credit Union
            </button>

            <button class="experience-tab" data-company="company2">
                Wellessia
            </button>

            <button class="experience-tab" data-company="company3">
                Babuland LTD
            </button>
        </div>

        <!-- Content -->
        <div class="md:w-3/4 md:pl-6 space-y-10">

            <!-- Company 1 -->
            <div class="company-content" id="company1">
                <p class="experience-role">
                    Nov 2024 – Present | Trainee Software Developer (Full Time)
                </p>

                <ul class="experience-list">
                    <li>Working on internal tools and web applications using .NET and C#.</li>
                    <li>Collaborating with teams to implement modern UI and backend solutions.</li>
                    <li>Learning and contributing to real-world enterprise projects.</li>
                </ul>
            </div>

            <!-- Company 2 -->
            <div class="company-content hidden" id="company2">
                <p class="experience-role">
                    Aug 2024 – Nov 2024 | Video Editor (Full Time)
                </p>

                <ul class="experience-list">
                    <li>Created promotional and tutorial videos for marketing campaigns.</li>
                    <li>Edited and optimized video content for social media platforms.</li>
                    <li>Worked with the creative team to enhance visual storytelling.</li>
                </ul>
            </div>

            <!-- Company 3 -->
            <div class="company-content hidden" id="company3">
                <p class="experience-role">
                    May 2022 – Oct 2023 | Compliance Associate (Part-Time)
                </p>

                <ul class="experience-list">
                    <li>Supported software projects with backend and frontend tasks.</li>
                    <li>Assisted in database management and UI updates.</li>
                    <li>Contributed to multiple small-scale development initiatives.</li>
                </ul>
            </div>

        </div>
    </div>
</section>


<!-- Showcase Section -->
<section id="showcase" class="py-16 bg-transparent section-reveal">
    <h2
        class="text-3xl md:text-4xl font-extrabold uppercase tracking-wider text-[#FFF1F1] text-center mb-8 flex items-center justify-center">
        <span class="border-t border-[#64ffda]/50 flex-[0_0_60px] mr-3"></span>
        Showcase
        <span class="border-t border-[#64ffda]/50 flex-[0_0_60px] ml-3"></span>
    </h2>

    <div class="project-list" data-aos="fade-up">

        <!-- Project 1 -->
        <a href="#" class="project-item group">
            <div class="flex flex-col">
                <span class="project-title">Project One</span>
                <span class="text-sm text-[#8892b0] mt-1 group-hover:text-[#64ffda] transition-colors">.NET Web App /
                    Razor Pages</span>
            </div>
            <span class="project-meta hidden md:block">2024</span>
        </a>

        <!-- Project 2 -->
        <a href="#" class="project-item group">
            <div class="flex flex-col">
                <span class="project-title">Project Two</span>
                <span class="text-sm text-[#8892b0] mt-1 group-hover:text-[#64ffda] transition-colors">Interactive UI /
                    C# & JS</span>
            </div>
            <span class="project-meta hidden md:block">2023</span>
        </a>

        <!-- Project 3 (Placeholder for balance vibe) -->
        <a href="#" class="project-item group">
            <div class="flex flex-col">
                <span class="project-title">Portfolio V1</span>
                <span class="text-sm text-[#8892b0] mt-1 group-hover:text-[#64ffda] transition-colors">Personal Brand /
                    Design</span>
            </div>
            <span class="project-meta hidden md:block">2022</span>
        </a>

    </div>
</section>

<!-- Big Footer / Contact -->
<section id="contact" class="big-footer" data-aos="fade-up">
    <p class="text-[#64ffda] uppercase tracking-widest mb-4">Have a project?</p>

    <a href="mailto:your.email@example.com" class="group">
        <h2 class="text-footer-massive">
            LET'S<br>TALK
        </h2>
    </a>

    <div class="flex gap-4 mt-8">
        <a href="mailto:your.email@example.com" class="glass-btn">Email Me</a>
        <a href="https://linkedin.com" target="_blank" class="glass-btn">LinkedIn</a>
    </div>
</section>

<footer class="py-6 text-center border-t border-[#64ffda]/30 text-[#e6f1ff] opacity-60">
    &copy; 2025 Brian Kabbo Sarker. Crafted with .NET
</footer>

@section Scripts {
    <!-- Script moved to layout.js to avoid duplication -->
}
