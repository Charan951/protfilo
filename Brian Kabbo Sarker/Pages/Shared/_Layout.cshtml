<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Brian_Kabbo_Sarker</title>

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        playfair: ['"Playfair Display"', 'serif'],
                    }
                }
            }
        }
    </script>

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/navbar.css" asp-append-version="true" />

    <!-- AOS Animations -->
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet">
</head>
<body class="bg-[#0a192f] font-playfair text-[#e6f1ff]">

    <!-- Navbar -->
    <nav id="navbar"
         class="fixed top-4 left-1/2 transform -translate-x-1/2 z-50
                flex justify-center items-center space-x-8 px-8 py-3
                rounded-full border shadow-lg opacity-0 -translate-y-6 transition-all duration-700">
        <a href="#home" class="relative nav-link font-medium hover:text-[#64ffda] transition duration-300">Home</a>
        <a href="#about" class="relative nav-link font-medium hover:text-[#64ffda] transition duration-300">About Me</a>
        <a href="#showcase" class="relative nav-link font-medium hover:text-[#64ffda] transition duration-300">Showcase</a>
        <a href="#contact" class="relative nav-link font-medium hover:text-[#64ffda] transition duration-300">Contact</a>
    </nav>

    <!-- Get in Touch Button -->
    <a href="#contact" class="fixed bottom-6 right-6 glass-btn z-50">
        Get in Touch
    </a>

    <!-- Main Content -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- Scripts -->
    <script src="~/js/navbar.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 800, once: true });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
