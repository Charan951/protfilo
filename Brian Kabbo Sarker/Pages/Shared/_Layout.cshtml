<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Brian Kabbo Sarker</title>

    <!-- SEO Meta Tags -->
    <meta name="description"
        content="Brian Kabbo Sarker — Software Developer specialising in .NET and C# web applications. Based in Bangladesh." />
    <meta name="author" content="Brian Kabbo Sarker" />
    <meta property="og:title" content="Brian Kabbo Sarker" />
    <meta property="og:description"
        content="Software Developer building interactive and reliable web applications with .NET and C#." />
    <meta property="og:image" content="/images/profile-photo.jpg" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Brian Kabbo Sarker" />
    <meta name="twitter:description"
        content="Software Developer building interactive and reliable web applications with .NET and C#." />

    <!-- Google Fonts — Poppins (headings), Inter (body), JetBrains Mono (code) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
        rel="stylesheet">

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="~/js/tailwind.config.js"></script>

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />

    <!-- AOS Animations -->
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet">


    <!-- Favicon -->
    <link rel="icon" type="image/png" href="~/images/logo.png" />
    <style>
        /* loader.css inline for immediate paint */
        #global-loader {
            display: none !important;
            /* Loader temporarily hidden */
            background: #07060f;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: fixed;
            inset: 0;
            z-index: 99999;
            font-family: inherit;
            transition: opacity 0.6s ease-out;
        }

        /* ── Grid background ── */
        .loader-grid {
            position: absolute;
            inset: 0;
            z-index: 0;
            background-image:
                linear-gradient(rgba(168, 85, 247, 0.08) 1px, transparent 1px),
                linear-gradient(90deg, rgba(168, 85, 247, 0.08) 1px, transparent 1px);
            background-size: 48px 48px;
            /* Fixed sized for smooth panning */
            animation: loader-grid-pan 12s linear infinite;
        }

        @@keyframes loader-grid-pan {
            0% {
                background-position: 0 0;
            }

            100% {
                background-position: 48px 48px;
            }
        }

        .loader-glow {
            position: absolute;
            inset: 0;
            z-index: 1;
            pointer-events: none;
            background: radial-gradient(ellipse 55% 45% at 50% 50%,
                    rgba(124, 58, 237, 0.18) 0%,
                    rgba(37, 99, 235, 0.08) 50%,
                    transparent 75%);
        }

        .loader-vignette {
            position: absolute;
            inset: 0;
            z-index: 2;
            pointer-events: none;
            background: radial-gradient(ellipse 80% 80% at 50% 50%, transparent 40%, #07060f 100%);
        }

        /* ── Content ── */
        .loader-content {
            position: relative;
            z-index: 10;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: clamp(20px, 4vw, 32px);
            padding: 0 5vw;
            text-align: center;
        }

        /* ── 3 pulsing dots ── */
        .loader-dots {
            display: flex;
            align-items: center;
            gap: clamp(8px, 1.5vw, 14px);
        }

        .loader-dot {
            width: clamp(8px, 1.5vw, 12px);
            height: clamp(8px, 1.5vw, 12px);
            border-radius: 50%;
            background: #ffffff;
            animation: loader-pulse 1.2s ease-in-out infinite;
        }

        .loader-dot:nth-child(1) {
            animation-delay: 0s;
        }

        .loader-dot:nth-child(2) {
            animation-delay: 0.2s;
        }

        .loader-dot:nth-child(3) {
            animation-delay: 0.4s;
        }

        @@keyframes loader-pulse {

            0%,
            100% {
                transform: scale(0.5);
                opacity: 0.2;
            }

            50% {
                transform: scale(1.3);
                opacity: 1;
            }
        }

        /* ── Text ── */
        .loader-text {
            color: #ffffff;
            font-size: clamp(16px, 3vw, 28px);
            font-weight: 500;
            letter-spacing: 0.04em;
            margin: 0;
        }

        .loader-text span {
            color: #a855f7;
        }
    </style>
</head>

<body class="bg-[#0a192f] font-playfair text-[#e6f1ff]">

    <!-- Global Loader -->
    <div id="global-loader">
        <div class="loader-grid"></div>
        <div class="loader-glow"></div>
        <div class="loader-vignette"></div>

        <div class="loader-content">
            <div class="loader-dots">
                <div class="loader-dot"></div>
                <div class="loader-dot"></div>
                <div class="loader-dot"></div>
            </div>
            <p class="loader-text">Loading <span>Brian Kabbo's</span> Portfolio</p>
        </div>
    </div>

    <!-- Navbar -->
    <!-- Navigation -->
    <nav id="navbar" class="fixed top-4 left-1/2 transform -translate-x-1/2 z-50
                w-[90%] max-w-4xl opacity-0 -translate-y-6 transition-all duration-700">

        <!-- Desktop Nav (Pill) -->
        <div class="hidden md:flex justify-center items-center space-x-8 px-8 py-3
                    rounded-full border shadow-lg bg-[#0a192f]/90 backdrop-blur-md">
            <a href="#home" class="nav-link font-medium hover:text-[#64ffda] transition duration-300">Home</a>
            <a href="#about" class="nav-link font-medium hover:text-[#64ffda] transition duration-300">About Me</a>
            <a href="#experience"
                class="nav-link font-medium hover:text-[#64ffda] transition duration-300">Experience</a>
            <a href="#showcase" class="nav-link font-medium hover:text-[#64ffda] transition duration-300">Showcase</a>
            <a href="#contact" class="nav-link font-medium hover:text-[#64ffda] transition duration-300">Contact</a>
        </div>

        <!-- Mobile Nav Bar (Top Bar) -->
        <div class="md:hidden flex justify-between items-center px-6 py-3
                    rounded-full border shadow-lg bg-[#0a192f]/90 backdrop-blur-md">
            <div class="text-[#64ffda] font-bold text-xl">BKS</div>

            <!-- Hamburger Button -->
            <button id="mobile-menu-btn" aria-label="Open navigation menu" aria-expanded="false"
                aria-controls="mobile-menu" class="text-[#e6f1ff] focus:outline-none">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16">
                    </path>
                </svg>
            </button>
        </div>

        <!-- Mobile Menu Overlay (Hidden by Default) -->
        <div id="mobile-menu" class="hidden absolute top-16 left-0 right-0 
                    flex flex-col items-center space-y-6 py-8
                    rounded-2xl border shadow-xl bg-[#0a192f]/95 backdrop-blur-xl">
            <a href="#home" class="mobile-link text-lg font-medium hover:text-[#64ffda]">Home</a>
            <a href="#about" class="mobile-link text-lg font-medium hover:text-[#64ffda]">About Me</a>
            <a href="#experience" class="mobile-link text-lg font-medium hover:text-[#64ffda]">Experience</a>
            <a href="#showcase" class="mobile-link text-lg font-medium hover:text-[#64ffda]">Showcase</a>
            <a href="#contact" class="mobile-link text-lg font-medium hover:text-[#64ffda]">Contact</a>
        </div>
    </nav>

    <!-- Get in Touch Button -->
    <a href="#contact" class="fixed bottom-6 right-6 get-in-touch-btn z-50" id="get-in-touch-btn">
        <span>Get in Touch</span>
    </a>

    <!-- Main Content -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>

    <script src="~/js/layout.js" asp-append-version="true"></script>
    <script>
        AOS.init({ duration: 800, once: true });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Loader fade out
        if (sessionStorage.getItem('loaderHasFired') === 'true') {
            document.getElementById('global-loader').style.display = 'none';
        } else {
            // Simulate minimal load time to show off the animation
            setTimeout(() => {
                const loader = document.getElementById('global-loader');
                if (loader) {
                    loader.style.opacity = '0';
                    setTimeout(() => {
                        loader.style.display = 'none';
                        sessionStorage.setItem('loaderHasFired', 'true');
                    }, 600);
                }
            }, 1800);
        }
    </script>
</body>

</html>
