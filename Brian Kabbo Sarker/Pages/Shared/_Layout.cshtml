<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Brian Kabbo Sarker</title>

    <!-- SEO Meta Tags -->
    <meta name="description"
        content="Brian Kabbo Sarker — Software Developer specialising in .NET and C# web applications. Based in Bangladesh." />
    <meta name="author" content="Brian Kabbo Sarker" />
    <meta property="og:title" content="Brian Kabbo Sarker" />
    <meta property="og:description"
        content="Software Developer building interactive and reliable web applications with .NET and C#." />
    <meta property="og:image" content="/images/profile-photo.jpg" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Brian Kabbo Sarker" />
    <meta name="twitter:description"
        content="Software Developer building interactive and reliable web applications with .NET and C#." />

    <!-- Google Fonts — Poppins (headings), Inter (body), JetBrains Mono (code) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
        rel="stylesheet">

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="~/js/tailwind.config.js"></script>

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />

    <!-- AOS Animations -->
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet">


    <!-- Favicon -->
    <link rel="icon" type="image/png" href="~/images/logo.png" />
    <style>
        /* loader.css inline for immediate paint */
        #global-loader {
            display: none !important;
            /* Loader temporarily hidden */
            background: #000000;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: fixed;
            inset: 0;
            z-index: 99999;
            font-family: inherit;
            transition: opacity 0.6s ease-out;
        }

        /* ── Content ── */
        .loader-content {
            position: relative;
            z-index: 10;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: clamp(24px, 5vw, 40px);
            padding: 0 5vw;
            text-align: center;
        }

        /* ── Minimal Spinner Animation ── */
        .loader-spinner {
            width: clamp(40px, 8vw, 60px);
            height: clamp(40px, 8vw, 60px);
            border: 2px solid rgba(255, 255, 255, 0.1);
            border-top-color: #ffffff;
            border-radius: 50%;
            animation: loader-spin 0.8s linear infinite;
        }

        @@keyframes loader-spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* ── Text ── */
        .loader-text {
            color: #ffffff;
            font-size: clamp(20px, 4vw, 36px);
            font-family: 'Poppins', sans-serif;
            font-weight: 800;
            letter-spacing: -0.02em;
            margin: 0;
        }

        .loader-text span {
            color: #ffffff;
            opacity: 0.6;
        }
    </style>
</head>

<body class="bg-[#000000] font-playfair text-[#ffffff]">

    <!-- Global Loader -->
    <div id="global-loader">
        <div class="loader-content">
            <div class="loader-spinner"></div>
            <p class="loader-text">Loading <span>Brian Kabbo</span></p>
        </div>
    </div>

    <!-- Navbar -->
    <!-- Navigation -->
    <nav id="navbar" class="fixed top-6 left-1/2 transform -translate-x-1/2 z-50
                w-[90%] max-w-4xl opacity-0 -translate-y-6 transition-all duration-700">

        <!-- Desktop Nav (Pill) -->
        <div class="hidden md:flex justify-center items-center space-x-10 px-10 py-4
                    rounded-full border border-[#333333] shadow-2xl bg-[#000000]/90 backdrop-blur-xl">
            <a href="#home" class="nav-link font-bold hover:text-[#ffffff] transition duration-300">Home</a>
            <a href="#about" class="nav-link font-bold hover:text-[#ffffff] transition duration-300">About</a>
            <a href="#experience"
                class="nav-link font-bold hover:text-[#ffffff] transition duration-300">Experience</a>
            <a href="#showcase" class="nav-link font-bold hover:text-[#ffffff] transition duration-300">Work</a>
            <a href="#contact" class="nav-link font-bold hover:text-[#ffffff] transition duration-300">Contact</a>
        </div>

        <!-- Mobile Nav Bar (Top Bar) -->
        <div class="md:hidden flex justify-between items-center px-6 py-4
                    rounded-full border border-[#333333] shadow-2xl bg-[#000000]/90 backdrop-blur-xl">
            <div class="text-[#ffffff] font-extrabold text-2xl tracking-tighter">BKS</div>

            <!-- Hamburger Button -->
            <button id="mobile-menu-btn" aria-label="Open navigation menu" aria-expanded="false"
                aria-controls="mobile-menu" class="text-[#ffffff] focus:outline-none">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16">
                    </path>
                </svg>
            </button>
        </div>

        <!-- Mobile Menu Overlay (Hidden by Default) -->
        <div id="mobile-menu" class="hidden absolute top-20 left-0 right-0 
                    flex flex-col items-center space-y-8 py-10
                    rounded-3xl border border-[#333333] shadow-2xl bg-[#000000]/98 backdrop-blur-2xl">
            <a href="#home" class="mobile-link text-xl font-bold">Home</a>
            <a href="#about" class="mobile-link text-xl font-bold">About</a>
            <a href="#experience" class="mobile-link text-xl font-bold">Experience</a>
            <a href="#showcase" class="mobile-link text-xl font-bold">Work</a>
            <a href="#contact" class="mobile-link text-xl font-bold">Contact</a>
        </div>
    </nav>

    <!-- Get in Touch Button -->
    <a href="#contact" class="fixed bottom-6 right-6 get-in-touch-btn z-50" id="get-in-touch-btn">
        <span>Get in Touch</span>
    </a>

    <!-- Main Content -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>

    <script src="~/js/layout.js" asp-append-version="true"></script>
    <script>
        AOS.init({ duration: 800, once: true });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Loader fade out
        if (sessionStorage.getItem('loaderHasFired') === 'true') {
            document.getElementById('global-loader').style.display = 'none';
        } else {
            // Simulate minimal load time to show off the animation
            setTimeout(() => {
                const loader = document.getElementById('global-loader');
                if (loader) {
                    loader.style.opacity = '0';
                    setTimeout(() => {
                        loader.style.display = 'none';
                        sessionStorage.setItem('loaderHasFired', 'true');
                    }, 600);
                }
            }, 1800);
        }
    </script>
</body>

</html>
